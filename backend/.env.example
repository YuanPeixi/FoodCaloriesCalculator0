# OpenRouter API Key (required for OpenRouter model)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter Model to use (default: qwen/qwen2.5-vl-72b-instruct)
# Options: qwen/qwen2.5-vl-72b-instruct, qwen/qwen-vl-plus, etc.
OPENROUTER_MODEL=qwen/qwen2.5-vl-72b-instruct

# Default recognition model: "openrouter" or "local"
DEFAULT_MODEL=openrouter
